# Servidor
PORT=3000
# Interfaz de escucha. 0.0.0.0 expone el servicio fuera del contenedor/host.
HOST=0.0.0.0

# Base de datos MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=codevote_db

# Autenticación (usar una cadena larga y distinta en cada entorno)
JWT_SECRET=cambia_esto_por_una_cadena_segura_de_minimo_32_caracteres
JWT_EXPIRES_IN=1h

# Orígenes permitidos por CORS, separados por coma.
# Si se deja vacío se permite cualquier origen (solo para pruebas locales).
CORS_ORIGIN=https://codevote.lat
